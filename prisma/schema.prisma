// Prisma schema for Qorpera (v0)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RunSchedule {
  DAILY
  WEEKLY
  MONTHLY
}

enum AgentKind {
  ASSISTANT
  SALES_REP
  CUSTOMER_SUCCESS
  MARKETING_COORDINATOR
  FINANCE_ANALYST
  OPERATIONS_MANAGER
  EXECUTIVE_ASSISTANT
  RESEARCH_ANALYST
  SEO_SPECIALIST
}

enum AgentStatus {
  IDLE
  WORKING
  OFFLINE
}

enum SubmissionStatus {
  SUBMITTED
  ACCEPTED
  NEEDS_REVISION
}

enum InboxItemState {
  OPEN
  APPROVED
  NEEDS_CHANGES
  AGENT_FOLLOWUP
  PAUSED
}

enum DefaultAutonomy {
  DRAFT_ONLY
  APPROVAL
  AUTO
}

enum ConnectorCheckCadence {
  HOURLY
  DAILY
  MANUAL
}

enum ProjectHealth {
  GREEN
  YELLOW
  RED
}

enum ProjectTaskColumn {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum RunStatus {
  RUNNING
  DRAFTING
  BLOCKED
  FINISHED
}

enum ProviderName {
  OPENAI
  ANTHROPIC
  GOOGLE
}

enum CredentialMode {
  MANAGED
  BYOK
}

enum CredentialStatus {
  CONNECTED
  NEEDS_ATTENTION
  PENDING
}

enum ModelProvider {
  OPENAI
  OLLAMA
  ANTHROPIC
  GOOGLE
}

enum BusinessLogCategory {
  FINANCIAL
  PROJECT
  COLLABORATION
  OPERATIONS
  SALES
  MARKETING
  LEGAL
  GENERAL
}

enum BusinessLogSource {
  OWNER
  AGENT
  IMPORT
}

enum BusinessFileCategory {
  FINANCIAL
  PROJECT
  COLLABORATION
  OPERATIONS
  SALES
  MARKETING
  LEGAL
  GENERAL
}

enum AgentTriggerMode {
  MANUAL
  DELEGATED
  SCHEDULED
  HYBRID
}

enum DelegatedTaskStatus {
  QUEUED
  RUNNING
  REVIEW
  DONE
  FAILED
  PAUSED
}

enum RunnerNodeStatus {
  PENDING
  ONLINE
  OFFLINE
  REVOKED
}

enum LicenseKeyStatus {
  ACTIVE
  REDEEMED
  REVOKED
}

enum RunnerJobStatus {
  QUEUED
  LEASED
  RUNNING
  NEEDS_APPROVAL
  SUCCEEDED
  FAILED
  CANCELED
}

enum PlanTier {
  SOLO
  SMALL_BUSINESS
  MID_SIZE
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  username        String?   @unique
  passwordHash    String
  emailVerified   Boolean   @default(false)
  emailVerifyToken String?
  emailVerifyExp   DateTime?
  resetToken       String?
  resetTokenExp    DateTime?
  sessionRevokedAt DateTime?
  totpSecret       String?
  totpEnabled      Boolean   @default(false)
  onboardedAt      DateTime?
  tourCompletedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  jobs         HiredJob[]
  submissions  Submission[]
  preferences  UserPreference?
  inboxStates  InboxItemStatus[]
  inboxItems   InboxItem[]
  auditLogs    AuditLog[]
  projects     Project[]
  runs         Run[]
  credentials  ProviderCredential[]
  companySoul  CompanySoul?
  modelRoutes  ModelRoutePreference[]
  businessLogs BusinessLogEntry[]
  businessFiles BusinessFile[]
  advisorSessions AdvisorSession[]
  agentAutomationConfigs AgentAutomationConfig[]
  delegatedTasks DelegatedTask[]
  stripePayments StripePayment[]
  agentPurchaseOrders AgentPurchaseOrder[]
  stripeSubscriptions StripeSubscription[]
  runnerNodes    RunnerNode[]
  runnerJobs     RunnerJob[]
  runnerPolicy       RunnerPolicy?
  externalConnectors ExternalConnector[]
  skillCredentials   SkillCredential[]
  ollamaUsage        OllamaUsage[]
  agentMemories      AgentMemory[]
  licenseKeysCreated  AgentLicenseKey[] @relation("LicenseKeyCreator")
  licenseKeysRedeemed AgentLicenseKey[] @relation("LicenseKeyRedeemer")
  planLicenseKeysCreated  PlanLicenseKey[] @relation("PlanLicenseKeyCreator")
  planLicenseKeysRedeemed PlanLicenseKey[] @relation("PlanLicenseKeyRedeemer")
  agentFeedback       AgentFeedback[]
  planSubscriptions        PlanSubscription[]
  optimizationCycles       AgentOptimizationCycle[]
  optimizationApplications AgentOptimizationApplication[]
  integrationConnections   IntegrationConnection[]
  webhookEvents            WebhookEvent[]
  schedules                Schedule[]
}

model HiredJob {
  id         String      @id @default(cuid())
  userId     String
  title      String
  agentKind  AgentKind
  schedule   RunSchedule
  enabled    Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentPurchaseOrder {
  id               String      @id @default(cuid())
  userId           String
  agentKind        AgentKind
  schedule         RunSchedule
  amountCents      Int         @default(0)
  currency         String      @default("usd")
  status           String      @default("PENDING")
  checkoutSessionId String?    @unique
  stripeEventId    String?
  stripePaymentId  String?
  stripeSubscriptionId String?
  failureReason    String?
  purchaseMode     String      @default("LEGACY_AGENT")
  fulfilledAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
}

model Agent {
  id        String      @id @default(cuid())
  kind      AgentKind   @unique
  name      String
  username  String?     @unique
  status    AgentStatus @default(IDLE)
  headline  String?
  updatedAt DateTime    @updatedAt
}

model Submission {
  id          String           @id @default(cuid())
  userId      String
  agentKind   AgentKind
  title       String
  output      String
  status      SubmissionStatus @default(SUBMITTED)
  rating      Int?
  correction  String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id                    String               @id @default(cuid())
  userId                String               @unique
  defaultAutonomy       DefaultAutonomy      @default(APPROVAL)
  requirePreview        Boolean              @default(true)
  enableRollback        Boolean              @default(true)
  justDoItMode          Boolean              @default(true)
  compactDashboard      Boolean              @default(false)
  highlightApprovals    Boolean              @default(true)
  connectorChecks       ConnectorCheckCadence @default(DAILY)
  maxAgentOutputTokens  Int                  @default(8192)
  notifyApprovalNeeded  Boolean              @default(true)
  notifySubmissionReady Boolean              @default(true)
  notifyTaskCompleted   Boolean              @default(true)
  notifyTaskFailed      Boolean              @default(true)
  updatedAt             DateTime             @updatedAt
  createdAt             DateTime             @default(now())

  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InboxItemStatus {
  id         String        @id @default(cuid())
  userId     String
  itemId     String
  state      InboxItemState @default(OPEN)
  stateLabel String        @default("Open")
  updatedAt  DateTime      @updatedAt
  createdAt  DateTime      @default(now())

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model InboxItem {
  id         String         @id @default(cuid())
  userId     String
  type       String         @default("draft")
  summary    String
  impact     String
  owner      String
  department String
  state      InboxItemState @default(OPEN)
  stateLabel String         @default("Open")
  sourceType          String         @default("DELEGATED_TASK")
  sourceId            String?
  digest              String?
  pendingActionsJson  String?
  executionResultJson String?
  createdAt           DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, state, createdAt])
  @@index([userId, sourceType, sourceId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId     String
  scope     String
  entityId   String
  action    String
  summary   String
  metadata  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope, createdAt])
}

model Template {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  outcome     String
  workflow    String
  permissions String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  roles       TemplateAgentRole[]
}

model TemplateAgentRole {
  id         String   @id @default(cuid())
  templateId String
  role       String
  sortOrder  Int      @default(0)

  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model Project {
  id             String         @id @default(cuid())
  userId         String
  slug           String
  name           String
  goal           String
  status         String         @default("Active")
  workforceHealth ProjectHealth @default(GREEN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          ProjectTask[]
  artifacts      ProjectArtifact[]
  runs           Run[]

  @@unique([userId, slug])
  @@index([userId, createdAt])
}

model ProjectTask {
  id         String          @id @default(cuid())
  projectId   String
  externalId String?
  title      String
  owner      String
  etaLabel   String
  column     ProjectTaskColumn
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, column, sortOrder])
}

model ProjectArtifact {
  id        String   @id @default(cuid())
  projectId  String
  name      String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Run {
  id         String    @id @default(cuid())
  userId     String
  projectId   String?
  name       String
  status     RunStatus
  etaLabel   String
  soulSnapshotVersion String?
  soulSnapshotJson    String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
}

model ExternalConnector {
  id             String   @id @default(cuid())
  userId         String
  connector      String   // "resend" | "sendgrid" | "postmark" | "webhook"
  label          String?
  encryptedKey   String?
  keyLast4       String?
  fromAddress    String?
  enabled        Boolean  @default(true)
  lastTestedAt   DateTime?
  lastTestStatus String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, connector])
  @@index([userId, enabled])
}

model ProviderCredential {
  id            String           @id @default(cuid())
  userId        String
  provider      ProviderName
  mode          CredentialMode   @default(MANAGED)
  label         String?
  encryptedKey  String?
  keyLast4      String?
  status        CredentialStatus @default(PENDING)
  monthlyRequestLimit Int        @default(500)
  monthlyRequestCount Int        @default(0)
  monthlyUsdLimit     Float      @default(10)
  monthlyEstimatedUsd Float      @default(0)
  usageMonthKey       String?
  lastTestedAt        DateTime?
  lastTestStatus      String?
  lastTestMessage     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, provider, updatedAt])
}

model CompanySoul {
  id                   String   @id @default(cuid())
  userId               String   @unique
  companyName          String   @default("")
  oneLinePitch         String   @default("")
  mission              String   @default("")
  idealCustomers       String   @default("")
  coreOffers           String   @default("")
  revenueModel         String   @default("")
  strategicGoals       String   @default("")
  constraints          String   @default("")
  brandVoice           String   @default("")
  departments          String   @default("")
  operatingCadence     String   @default("")
  approvalRules        String   @default("")
  toolsAndSystems      String   @default("")
  keyMetrics           String   @default("")
  glossary             String   @default("")
  notesForAgents       String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ModelRoutePreference {
  id        String        @id @default(cuid())
  userId    String
  target    String
  provider  ModelProvider @default(OPENAI)
  modelName String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, target])
  @@index([userId, target])
}

model BusinessLogEntry {
  id           String            @id @default(cuid())
  userId       String
  title        String
  category     BusinessLogCategory @default(GENERAL)
  source       BusinessLogSource @default(OWNER)
  authorLabel  String?
  body         String
  relatedRef   String?
  locked       Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, category, createdAt])
}

model BusinessFile {
  id          String              @id @default(cuid())
  userId      String
  name        String
  category    BusinessFileCategory @default(GENERAL)
  mimeType    String?
  sizeBytes   Int                 @default(0)
  storagePath String
  textExtract String?
  source      BusinessLogSource   @default(OWNER)
  authorLabel String?
  relatedRef  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, category, createdAt])
}

model StripePayment {
  id               String    @id @default(cuid())
  userId           String
  stripeEventId    String?
  checkoutSessionId String   @unique
  paymentIntentId  String?
  amountTotal      Int       @default(0)
  currency         String    @default("usd")
  paymentStatus    String    @default("unknown")
  mode             String    @default("payment")
  agentKind        String?
  schedule         String?
  metadataJson     String?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, paidAt])
  @@index([userId, paymentStatus, createdAt])
}

model StripeSubscription {
  id                 String    @id @default(cuid())
  userId             String
  stripeSubscriptionId String  @unique
  stripeCustomerId   String?
  stripePriceId      String?
  status             String    @default("incomplete")
  agentKind          String?
  schedule           String?
  cancelAtPeriodEnd  Boolean   @default(false)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  metadataJson       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status, updatedAt])
}

model AdvisorSession {
  id         String          @id @default(cuid())
  userId     String
  title      String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   AdvisorMessage[]

  @@index([userId, updatedAt])
}

model AdvisorMessage {
  id         String        @id @default(cuid())
  sessionId  String
  role       String
  content    String
  source     String?
  modelName  String?
  createdAt  DateTime      @default(now())

  session    AdvisorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AgentAutomationConfig {
  id             String          @id @default(cuid())
  userId         String
  agentTarget    String
  triggerMode    AgentTriggerMode @default(MANUAL)
  wakeOnDelegation Boolean       @default(true)
  scheduleEnabled Boolean        @default(false)
  dailyTimesCsv  String          @default("")
  timezone       String          @default("UTC")
  runContinuously Boolean        @default(false)
  maxLoopIterations Int          @default(3)
  maxAgentCallsPerRun Int        @default(6)
  maxToolRetries    Int          @default(2)
  maxRuntimeSeconds Int          @default(120)
  heartbeatEnabled      Boolean  @default(false)
  heartbeatIntervalMin  Int      @default(15)
  requireApprovalForExternalActions Boolean @default(true)
  allowAgentDelegation            Boolean @default(true)
  integrationsCsv String         @default("")
  notes          String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentTarget])
  @@index([userId, triggerMode, updatedAt])
}

model DelegatedTask {
  id               String            @id @default(cuid())
  userId           String
  fromAgent        String
  toAgentTarget    String
  title            String
  instructions     String
  status           DelegatedTaskStatus @default(QUEUED)
  triggerSource    String            @default("DELEGATED")
  scheduledFor     DateTime?
  dueLabel         String?
  projectRef       String?
  completionDigest String?
  inputFromTaskId  String?
  attempts         Int               @default(0)
  maxAttempts      Int               @default(3)
  chainDepth       Int               @default(0)
  webhookEventId   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  completedAt      DateTime?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls        DelegatedTaskToolCall[]

  @@index([userId, toAgentTarget, status, createdAt])
  @@index([userId, createdAt])
}

model DelegatedTaskToolCall {
  id            String   @id @default(cuid())
  delegatedTaskId String
  toolName      String
  phase         String
  status        String
  latencyMs     Int?
  inputSummary  String?
  outputSummary String?
  createdAt     DateTime @default(now())

  delegatedTask DelegatedTask @relation(fields: [delegatedTaskId], references: [id], onDelete: Cascade)

  @@index([delegatedTaskId, createdAt])
}

model RunnerNode {
  id               String           @id @default(cuid())
  userId           String
  name             String
  environment      String           @default("desktop")
  status           RunnerNodeStatus @default(PENDING)
  authTokenHash    String
  authTokenLast4   String?
  label            String?
  hostName         String?
  osName           String?
  runnerVersion    String?
  capabilitiesJson String?
  lastSeenAt       DateTime?
  lastIp           String?
  metadataJson     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs             RunnerJob[]

  @@index([userId, createdAt])
  @@index([userId, status, updatedAt])
  @@index([lastSeenAt])
}

model RunnerJob {
  id               String          @id @default(cuid())
  userId           String
  runnerNodeId     String?
  jobType          String
  title            String
  status           RunnerJobStatus @default(QUEUED)
  riskLevel        String          @default("medium")
  payloadJson      String
  resultJson       String?
  errorMessage     String?
  leaseToken       String?
  leaseExpiresAt   DateTime?
  attempts         Int             @default(0)
  maxAttempts      Int             @default(1)
  requestedBy      String?
  approvalRequired Boolean         @default(false)
  approvedAt       DateTime?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  runnerNode       RunnerNode?     @relation(fields: [runnerNodeId], references: [id], onDelete: SetNull)
  events           RunnerJobEvent[]
  controls         RunnerJobControl[]

  @@index([userId, status, createdAt])
  @@index([runnerNodeId, status, updatedAt])
  @@index([leaseExpiresAt])
}

model RunnerJobEvent {
  id            String   @id @default(cuid())
  runnerJobId    String
  eventType      String
  level          String   @default("info")
  message        String
  dataJson       String?
  createdAt      DateTime @default(now())

  runnerJob      RunnerJob @relation(fields: [runnerJobId], references: [id], onDelete: Cascade)

  @@index([runnerJobId, createdAt])
}

model RunnerJobControl {
  id            String   @id @default(cuid())
  runnerJobId    String
  kind          String
  status        String   @default("PENDING")
  payloadJson    String
  createdAt      DateTime @default(now())
  appliedAt      DateTime?

  runnerJob      RunnerJob @relation(fields: [runnerJobId], references: [id], onDelete: Cascade)

  @@index([runnerJobId, status, createdAt])
}

model RunnerPolicy {
  id           String   @id @default(cuid())
  userId        String   @unique
  templateKey   String   @default("default")
  templateName  String   @default("Default workspace template")
  version       Int      @default(1)
  rulesJson     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([templateKey, updatedAt])
}

model SkillCredential {
  id           String   @id @default(cuid())
  userId       String
  varName      String   // e.g. "OPENAI_API_KEY", "SENTRY_AUTH_TOKEN"
  encryptedKey String
  keyLast4     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, varName])
  @@index([userId])
}

model ToolDefinition {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String
  parametersJson  String
  executionMode   String   @default("in_process")
  category        String   @default("general")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agentToolSets   AgentKindToolSet[]

  @@index([category, enabled])
}

model AgentKindToolSet {
  id               String   @id @default(cuid())
  agentKind        String
  toolDefinitionId String
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())

  toolDefinition   ToolDefinition @relation(fields: [toolDefinitionId], references: [id], onDelete: Cascade)

  @@unique([agentKind, toolDefinitionId])
  @@index([agentKind, enabled])
}

model OllamaUsage {
  id               String   @id @default(cuid())
  userId           String
  monthKey         String   // "YYYY-MM"
  requestCount     Int      @default(0)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
  @@index([userId])
}

model AgentMemory {
  id           String   @id @default(cuid())
  userId       String
  agentKind    String
  indexContent String   @default("")
  entryCount   Int      @default(0)
  updatedAt    DateTime @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries AgentMemoryEntry[]

  @@unique([userId, agentKind])
  @@index([userId])
}

model AgentMemoryEntry {
  id            String   @id @default(cuid())
  agentMemoryId String
  topic         String
  title         String
  content       String
  importance    Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  agentMemory AgentMemory @relation(fields: [agentMemoryId], references: [id], onDelete: Cascade)

  @@index([agentMemoryId, importance])
}

model AgentLicenseKey {
  id             String           @id @default(cuid())
  creatorUserId  String
  agentKind      AgentKind
  schedule       RunSchedule
  code           String           @unique
  status         LicenseKeyStatus @default(ACTIVE)
  redeemedById   String?
  redeemedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  creator        User             @relation("LicenseKeyCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  redeemedBy     User?            @relation("LicenseKeyRedeemer", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([creatorUserId, createdAt])
  @@index([redeemedById])
}

model PlanLicenseKey {
  id             String           @id @default(cuid())
  creatorUserId  String
  tier           PlanTier
  code           String           @unique
  status         LicenseKeyStatus @default(ACTIVE)
  redeemedById   String?
  redeemedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  creator        User             @relation("PlanLicenseKeyCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  redeemedBy     User?            @relation("PlanLicenseKeyRedeemer", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([creatorUserId, createdAt])
  @@index([redeemedById])
}

model AgentFeedback {
  id         String   @id @default(cuid())
  userId     String
  agentKind  String
  message    String
  sourceRef  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Plan {
  id            String   @id @default(cuid())
  tier          PlanTier
  slug          String   @unique
  name          String
  headline      String   @default("")
  monthlyCents  Int
  agentCap      Int
  stripePriceId String?
  isActive      Boolean  @default(true)
  featuresJson  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions PlanSubscription[]
}

model PlanSubscription {
  id                   String    @id @default(cuid())
  userId               String
  planId               String
  status               String    @default("PENDING")
  source               String    @default("STRIPE") // "STRIPE" | "MANUAL"
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  checkoutSessionId    String?   @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId, status])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String
  label     String   @default("")
  enabled   Boolean  @default(false)
  userId    String?  // null = global; non-null = per-user override
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, userId])
}

model PlanInquiry {
  id            String   @id @default(cuid())
  tier          PlanTier
  name          String
  email         String
  companyName   String   @default("")
  employeeCount String   @default("")
  message       String   @default("")
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
}

// ── Webhook Endpoints ───────────────────────────────────────────

model WebhookEndpoint {
  id             String   @id @default(cuid())
  userId         String
  agentTarget    String
  label          String   @default("")
  secretHash     String
  secretLast4    String?
  enabled        Boolean  @default(true)
  lastCalledAt   DateTime?
  callCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, agentTarget])
  @@index([userId, enabled])
}

// ── Heartbeat Logs ──────────────────────────────────────────────

model HeartbeatLog {
  id             String   @id @default(cuid())
  userId         String
  agentTarget    String
  checkResult    String   @default("SKIP")  // SKIP | WAKE
  signalsFound   String?
  llmSavedMs     Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([userId, agentTarget, createdAt])
  @@index([userId, createdAt])
}

// ── Agent Optimizer ──────────────────────────────────────────────

model AgentOptimizationCycle {
  id            String   @id @default(cuid())
  userId        String
  agentKind     String   // "CHIEF_ADVISOR" | "ASSISTANT" | etc.
  status        String   @default("RUNNING") // RUNNING | COMPLETE | FAILED
  researchJson  String?  // JSON: array of {topic, technique, source, keyInsights, applicability}
  synthesisText String?  // AI-synthesized summary of key findings
  scoreJson     String?  // JSON: {overall, dimensions: [{name, score, rationale}]}
  improvementsJson String? // JSON: array of {id, dimension, priority, issue, recommendation, researchBasis, promptPatch}
  errorMessage  String?
  nextRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications AgentOptimizationApplication[]

  @@index([userId, agentKind, createdAt])
  @@index([userId, status, createdAt])
}

model IntegrationConnection {
  id                    String    @id @default(cuid())
  userId                String
  provider              String    // "hubspot" | "slack" | "google" | "linear"
  status                String    @default("CONNECTED")
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  scopes                String?
  metadataJson          String?   // portalId/hubDomain, workspace name, etc.
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model AgentOptimizationApplication {
  id             String   @id @default(cuid())
  userId         String
  cycleId        String
  agentKind      String
  improvementId  String
  dimension      String
  title          String
  patchText      String
  appliedAt      DateTime @default(now())

  user  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle AgentOptimizationCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([userId, agentKind, appliedAt])
  @@index([cycleId])
}

// ── Webhook Events (inbound provider events) ─────────────────────

model WebhookEvent {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  eventType    String
  payload      String    // raw JSON, max 65535 chars stored
  status       String    @default("PENDING") // PENDING|PROCESSING|PROCESSED|FAILED|SKIPPED
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([userId, provider, createdAt])
}

model Schedule {
  id           String            @id @default(cuid())
  userId       String
  agentKind    String
  title        String
  instructions String
  frequency    ScheduleFrequency
  dayOfWeek    Int?
  dayOfMonth   Int?
  timeOfDay    String
  timezone     String            @default("UTC")
  enabled      Boolean           @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enabled, nextRunAt])
  @@index([userId])
}
